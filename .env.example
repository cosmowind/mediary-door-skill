# Mediary 环境变量配置
# 复制此文件为 .env 并填入你的实际配置

# Mediary 后端地址（含 /api/v1 路径）
# dev 环境示例：http://127.0.0.1:9000/api/v1
# production 示例：https://your-domain.com/api/v1
MEDIARY_BASE_URL=http://127.0.0.1:9000/api/v1

# Mediary API Key（从前端 TOTP 管理页 → AI 接口密钥 生成）
MEDIARY_API_KEY=your_api_key_here

# 可选：书签文档 ID（用于快速访问常用文档）
# MEDIARY_BOOKMARK_PLAN=1234
# MEDIARY_BOOKMARK_LOG=5678
